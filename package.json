{
  "name": "playwright-e2e-pack-demo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run typecheck && node scripts/build-site.mjs",
    "start": "node server.js",
    "build:evidence": "node scripts/build-evidence.mjs",
    "validate:public-artifacts": "node scripts/validate-public-artifacts.mjs",
    "scan:secrets": "node scripts/scan-secrets.mjs",
    "validate:docs": "node scripts/validate-docs.mjs",
    "validate:repo": "node scripts/validate-repo.mjs",
    "validate:workflows": "node scripts/validate-workflows.mjs",
    "serve": "node server.js",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "playwright test",
    "test:api": "playwright test tests/api",
    "test:ui": "playwright test tests/ui",
    "test:repeat": "playwright test --repeat-each=3 --retries=0",
    "test:sites": "npm run build && playwright test --config playwright.sites.config.ts",
    "validate:publication-inputs": "node scripts/validate-publication-inputs.mjs",
    "validate:regressions": "node scripts/validate-regression-manifest.mjs",
    "baseline:json": "node scripts/run-baseline.mjs",
    "prove:regressions": "node scripts/prove-regressions.mjs",
    "verify:quality": "node scripts/verify-quality.mjs",
    "validate:publication": "node scripts/validate-publication.mjs",
    "test:public": "node scripts/validate-publication.mjs && playwright test tests/smoke/public.spec.ts --retries=0 --workers=1",
    "release:check": "node scripts/release-check.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.20.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "wrangler": "4.112.0",
    "eslint-plugin-playwright": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
